# Copy to .env.local and fill in values

# Site chat → Make.com (JSON: { thread_id, message }). Optional; defaults to production hook.
# VITE_CHAT_WEBHOOK_URL=

# WhatsApp chat widget (ManyChat-connected number)
# Phone in international format without + (e.g. 14155551234)
VITE_WHATSAPP_PHONE=
# Optional pre-filled message (e.g. "Hi! I have a question about Pulse.")
VITE_WHATSAPP_PREFILL=

# The LO landing (/the-lo?key=…) → POST community_partners/add_member/ (staging when VITE_IS_STRIPE_TEST_MODE is not "false").
# VITE_THE_LO_PARTNER_COMMUNITY_ID=
